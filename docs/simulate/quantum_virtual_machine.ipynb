"""
FTP Uploader for cPanel hosting.
Uploads generated proposal letters to a remote directory.
"""

import ftplib
import os
import datetime


def upload_to_cpanel(
    content: str,
    host: str,
    username: str,
    password: str,
    remote_directory: str,
    filename: str = None,
) -> bool:
    """
    Upload a text file to cPanel hosting via FTP.

    Args:
        content: The text content to upload.
        host: FTP hostname (e.g., ftp.eheps.org).
        username: cPanel FTP username.
        password: cPanel FTP password.
        remote_directory: Remote folder (e.g., public_html/proposals).
        filename: Desired filename (optional; auto-generated if None).

    Returns:
        True if successful, False otherwise.
    """
    try:
        ftp = ftplib.FTP(host, username, password)
        print(f"[FTP] Connected to {host}")

        # Navigate into remote directory, creating subdirectories if needed
        if remote_directory:
            dirs = remote_directory.strip("/").split("/")
            for d in dirs:
                if d:
                    try:
                        ftp.cwd(d)
                    except ftplib.error_perm:
                        ftp.mkd(d)
                        ftp.cwd(d)
            print(f"[FTP] Working directory: /{remote_directory.strip('/')}")
        else:
            print("[FTP] Working directory: (root)")

        # Auto-generate filename if not provided
        if filename is None:
            timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
            filename = f"proposal_{timestamp}.txt"

        # Write content to a temporary local file
        local_tmp = f"/tmp/{filename}"
        with open(local_tmp, "w", encoding="utf-8") as f:
            f.write(content)

        # Upload
        with open(local_tmp, "rb") as f:
            ftp.storbinary(f"STOR {filename}", f)

        ftp.quit()
        print(f"[FTP] Successfully uploaded: {filename} -> /{remote_directory.strip('/')}/{filename}")

        # Clean up
        os.remove(local_tmp)
        return True


#!/usr/bin/env python3
"""
Main entry point for Google Entity Proposal Generator.
Interactive CLI with menu-driven interface.
"""

import sys
import yaml
from proposal_generator import ENTITIES, SENDER_EMAILS, generate_letter
from ftp_uploader import upload_to_cpanel


def load_config(config_path: str = "config.yaml") -> dict:
    """Load FTP configuration from YAML file."""
    try:
        with open(config_path, "r") as f:
            config = yaml.safe_load(f)
        return config.get("ftp", {})
    except FileNotFoundError:
        print(f"[WARNING] {config_path} not found. FTP upload will be skipped.")
        return {}
    except yaml.YAMLError as e:
        print(f"[ERROR] Invalid YAML in {config_path}: {e}")
        return {}


def select_option(options: list, prompt: str) -> str:
    """Display a numbered menu and return the selected option."""
    print(f"\n{prompt}")
    print("-" * 40)
    for i, option in enumerate(options, 1):
        print(f"  {i}. {option}")
    print("-" * 40)

    while True:
        try:
            choice = input("Enter number: ").strip()
            idx = int(choice) - 1
            if 0 <= idx < len(options):
                return options[idx]
            else:
                print(f"Please enter a number between 1 and {len(options)}.")
        except ValueError:
            print("Invalid input. Please enter a number.")


def confirm(prompt: str) -> bool:
    """Ask yes/no confirmation."""
    while True:
        ans = input(f"{prompt} (y/n): ").strip().lower()
        if ans in ("y", "yes"):
            return True
        elif ans in ("n", "no"):
            return False
        else:
            print("Please enter 'y' or 'n'.")


def main():
    print("=" * 60)
    print("  Google Entity Proposal Generator + cPanel FTP Upload")
    print("=" * 60)

    # Step 1: Select entity
    entity = select_option(ENTITIES, "Select Google entity type:")

    # Step 2: Select sender email
    sender_email = select_option(SENDER_EMAILS, "Select sender email address:")

    # Step 3: Generate letter
    letter = generate_letter(entity, sender_email)
    print("\n" + "=" * 60)
    print("  GENERATED LETTER")
    print("=" * 60)
    print(letter)
    print("=" * 60)

    # Step 4: Option to save locally
    if confirm("\nSave this letter to a local file?"):
        filename = input("Enter filename (or press Enter for default): ").strip()
        if not filename:
            from datetime import datetime

            timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
            filename = f"proposal_{timestamp}.txt"
        with open(filename, "w", encoding="utf-8") as f:
            f.write(letter)
        print(f"[SAVED] Letter saved to: {filename}")

    # Step 5: Option to upload via FTP
    ftp_config = load_config()
    if ftp_config and confirm("\nUpload this letter to cPanel via FTP?"):
        host = ftp_config.get("host", "")
        username = ftp_config.get("username", "")
        password = ftp_config.get("password", "")
        remote_dir = ftp_config.get("remote_directory", "public_html")

        # Override from input if config is incomplete
        if not host:
            host = input("FTP Host (e.g., ftp.eheps.org): ").strip()
        if not username:
            username = input("FTP Username: ").strip()
        if not password:
            password = input("FTP Password: ").strip()

        # Custom filename for FTP
        ftp_filename = input("Remote filename (or press Enter for auto): ").strip()
        if not ftp_filename:
            ftp_filename = None

        success = upload_to_cpanel(
            content=letter,
            host=host,
            username=username,
            password=password,
            remote_directory=remote_dir,
            filename=ftp_filename,
        )

        if success:
            print("\n[DONE] Proposal generated and uploaded successfully!")
        else:
            print("\n[WARNING] Proposal generated but FTP upload failed. Check credentials.")

    print("\nGoodbye!")


if __name__ == "__main__":
    main()


    except Exception as e:
        print(f"[FTP] ERROR: {e}")
        return False

