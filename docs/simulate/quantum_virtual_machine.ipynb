import ftplib
import os
import ipywidgets as widgets
from IPython.display import display, clear_output
from getpass import getpass

# --- FTP Upload UI ---
ftp_host = widgets.Text(
    value='ftp.eheps.org',   # change if different, e.g., ftp.eheps.com
    description='FTP Host:',
    style={'description_width': 'initial'}
)
ftp_user = widgets.Text(
    value='', 
    description='FTP Username:',
    style={'description_width': 'initial'}
)
ftp_pass = widgets.Password(
    value='', 
    description='FTP Password:',
    style={'description_width': 'initial'}
)
remote_dir = widgets.Text(
    value='public_html/proposals', 
    description='Remote Folder:',
    style={'description_width': 'initial'}
)
remote_filename = widgets.Text(
    value='', 
    description='File Name:',
    style={'description_width': 'initial'}
)

upload_btn = widgets.Button(description='Upload to cPanel')
upload_output = widgets.Output()

def on_upload_click(b):
    with upload_output:
        clear_output()
        if not generated_letter_text:
            print("ERROR: No letter generated yet. Run the 'Generate Letter' cell first.")
            return
        
        # Build the full remote file path
        directory = remote_dir.value.strip('/')
        filename = remote_filename.value.strip()
        if not filename:
            # Auto-generate filename based on entity and email
            entity_safe = entity_dropdown.value.replace(' ', '_').replace('/', '_')
            email_safe = email_dropdown.value.replace('@', '_at_').replace('.', '_')
            filename = f"{entity_safe}_{email_safe}.txt"
        
        remote_path = f"{directory}/{filename}" if directory else filename

        try:
            ftp = ftplib.FTP(host=ftp_host.value, user=ftp_user.value, passwd=ftp_pass.value)
            print(f"Connected to {ftp_host.value}")

            # Ensure the remote directory exists (navigate and create if needed)
            if directory:
                dirs = directory.split('/')
                for d in dirs:
                    if d:
                        try:
                            ftp.cwd(d)
                        except:
                            ftp.mkd(d)
                            ftp.cwd(d)
                # Go back to root to work with absolute path? ftplib works relative.
                # Alternatively, we can just STOR with the full path after creating dirs.
                # We'll create a local file, then upload.
            
            # Write the letter to a temporary local file
            local_tmp = f"/tmp/{filename}"
            with open(local_tmp, 'w') as f:
                f.write(generated_letter_text)
            
            # Upload
            with open(local_tmp, 'rb') as f:
                ftp.storbinary(f'STOR {filename}', f)  # filename only, since we are in the correct directory
            ftp.quit()
            print(f"SUCCESS: Uploaded {filename} to /{directory} on {ftp_host.value}")
            # Clean up local temp file
            os.remove(local_tmp)
        except Exception as e:
            print(f"ERROR: {e}")

upload_btn.on_click(on_upload_click)

display(ftp_host, ftp_user, ftp_pass, remote_dir, remote_filename, upload_btn, upload_output)

